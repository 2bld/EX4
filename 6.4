print("Calculadora Python")

while True:
    try:
        ope = input("Digite a operação: ")
        resultado = eval(ope)
        print("Resultado:", resultado)
        break

    except ZeroDivisionError:
        print("Erro: divisão por zero não é permitida. Tente novamente.")

    except Exception:
        print("Operação inválida. Tente novamente.")
